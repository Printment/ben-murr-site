\pard\sa180\sb180\f0\fs26\b\cf2 What each field does\b0\cf0\par
\par
\pard\sa120\sb160\f0\fs22\b\cf3 Title\b0\cf0\par
\par
\pard\sa180\f0\fs24 The page headline shown on the blog article page and in the blog list.\par
\par
\pard\sa120\sb160\f0\fs22\b\cf3 Slug\b0\cf0\par
\par
\pard\sa180\f0\fs24 The page URL.\par
\par
\pard\sa180\f0\fs24 Example:\par
\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab `crafting-a-personal-website-from-scratch-with-ai-part-1`\par
\par
\pard\sa120\sb160\f0\fs22\b\cf3 Publish date\b0\cf0\par
\par
\pard\sa180\f0\fs24 Used for date display and ordering on the blog.\par
\par
\pard\sa120\sb160\f0\fs22\b\cf3 Summary\b0\cf0\par
\par
\pard\sa180\f0\fs24 Used in cards, featured article panels and previews.\par
\par
\pard\sa120\sb160\f0\fs22\b\cf3 Cover image\b0\cf0\par
\par
\pard\sa180\f0\fs24 Used in the featured card, blog cards and the article hero.\par
\par
\pard\sa120\sb160\f0\fs22\b\cf3 Category\b0\cf0\par
\par
\pard\sa180\f0\fs24 Used for article theme and grouping.\par
\par
\pard\sa120\sb160\f0\fs22\b\cf3 Tags\b0\cf0\par
\par
\pard\sa180\f0\fs24 Used for supporting labels.\par
\par
\pard\sa120\sb160\f0\fs22\b\cf3 Featured article\b0\cf0\par
\par
\pard\sa180\f0\fs24 If checked, this article becomes the featured one used on:\par
\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab homepage latest article areas\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab blog landing featured area\par
\par
\pard\sa180\f0\fs24 If no article is featured, the newest article is usually used instead.\par
\par
\pard\sa120\sb160\f0\fs22\b\cf3 Body\b0\cf0\par
\par
\pard\sa180\f0\fs24 Main article content. This supports:\par
\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab text\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab inline images\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab image alt text\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab image captions\par
