\pard\sa220\sb260\f0\fs34\b\cf2 3. What you need open when working\b0\cf0\par
\par
\pard\sa180\sb180\f0\fs26\b\cf2 To edit content in Sanity\b0\cf0\par
\par
\pard\sa180\f0\fs24 Run:\par
\par
\pard\sa180\li360\ri360\cbpat1\cf5\f1\fs19
cd "/Users/benmurr/Documents/New project"\line 
npx sanity@latest dev --port 3333\line 
\par\pard\cf0\f0\fs24
\par
\pard\sa180\f0\fs24 Then open:\par
\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab `http://localhost:3333/structure`\par
\par
\pard\sa180\sb180\f0\fs26\b\cf2 To preview the website locally\b0\cf0\par
\par
\pard\sa180\f0\fs24 Run:\par
\par
\pard\sa180\li360\ri360\cbpat1\cf5\f1\fs19
cd "/Users/benmurr/Documents/New project"\line 
npm run dev\line 
\par\pard\cf0\f0\fs24
\par
\pard\sa180\f0\fs24 Then open:\par
\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab `http://localhost:3000`\par
\par
\pard\sa180\sb180\f0\fs26\b\cf2 If the port is already in use\b0\cf0\par
\par
\pard\sa180\f0\fs24 You may see a message saying another server is already running.\par
\par
\pard\sa180\f0\fs24 If that happens:\par
\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab use the existing localhost URL if it is already correct\par
\pard\sa120\li360\fi-180\f0\fs22 \\u8226?\tab or stop the old process and restart\par
\par
\pard\sa180\f0\fs24 Example:\par
\par
\pard\sa180\li360\ri360\cbpat1\cf5\f1\fs19
kill 48161\line 
npm run dev\line 
\par\pard\cf0\f0\fs24
\par
